# Anthropic API Configuration (Required)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Claude Model Configuration
# Use Haiku for fast, cheap evaluations (recommended)
# Use Sonnet for more complex reasoning (optional)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Approval Thresholds
# Minimum confidence for auto-approval (0.0-1.0)
APPROVAL_CONFIDENCE_THRESHOLD=0.8

# Maximum confidence for auto-denial (0.0-1.0)
DENIAL_CONFIDENCE_THRESHOLD=0.2

# Logging Configuration
LOG_LEVEL=INFO

# Audit Log
# Store all approval decisions for compliance/debugging
ENABLE_AUDIT_LOG=true
AUDIT_LOG_FILE=audit.jsonl

# Approval Cache (Performance Optimization)
# Cache Tier 3 AI decisions for repeated operations
ENABLE_APPROVAL_CACHE=true
# Cache time-to-live in seconds (default: 3600 = 1 hour)
CACHE_TTL_SECONDS=3600

# Pending Approval TTL
# How long pending human approvals remain valid (seconds)
PENDING_TTL_SECONDS=1800

# File Queue for Pending Approvals
# Write pending approvals to JSON files for external tool integration
PHLEGYAS_QUEUE_ENABLED=true
PHLEGYAS_QUEUE_DIR=~/.claude/pending-approvals

# macOS System Notifications (darwin only)
# Fire a system notification when a pending approval is created
PHLEGYAS_NOTIFY_MACOS=true

# Slack Integration (Optional)
# Bot OAuth token (starts with xoxb-)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
# App-level token for Socket Mode (starts with xapp-)
SLACK_APP_TOKEN=xapp-your-app-token-here
# Channel name (without #) to post approval requests
SLACK_APPROVAL_CHANNEL=approvals
# How long to wait for human response before auto-denying (seconds)
SLACK_APPROVAL_TIMEOUT_SECONDS=300

# Project Context (Optional)
# Helps AI make better decisions based on your project
PROJECT_NAME=My Project
PROJECT_TYPE=Software project
CURRENT_TASK=Development work
